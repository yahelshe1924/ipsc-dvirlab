# ──────────────────────────────────────────────────────────────
# iPSC-DvirLab · Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# ── Supabase (get from Supabase Dashboard → Project Settings → API) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Google OAuth (for Supabase Auth + Gmail + Calendar) ─────────────────────
# Create a project at console.cloud.google.com
# Enable: Gmail API, Google Calendar API, Google Identity
# Create OAuth 2.0 credentials (Web Application)
# Authorized redirect URI: https://YOUR_PROJECT.supabase.co/auth/v1/callback

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Gmail API (for sending emails from Edge Functions) ───────────────────────
# These go in Supabase Dashboard → Edge Functions → Secrets
# Obtain refresh token via: https://developers.google.com/oauthplayground
# Scopes needed: https://mail.google.com/
GMAIL_CLIENT_ID=same_as_GOOGLE_CLIENT_ID
GMAIL_CLIENT_SECRET=same_as_GOOGLE_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
FROM_EMAIL=your-lab-email@gmail.com

# ── Google Calendar API ───────────────────────────────────────────────────────
# Scopes needed: https://www.googleapis.com/auth/calendar
# Can reuse same OAuth client, but needs its own refresh token with calendar scope
GOOGLE_CALENDAR_CLIENT_ID=same_as_GOOGLE_CLIENT_ID
GOOGLE_CALENDAR_CLIENT_SECRET=same_as_GOOGLE_CLIENT_SECRET
GOOGLE_CALENDAR_REFRESH_TOKEN=your_calendar_refresh_token
